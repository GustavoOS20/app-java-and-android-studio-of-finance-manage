<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fundoColor">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar2"
        android:layout_width="0dp"
        android:layout_height="71dp"
        android:background="@color/menuColor"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/AddSaldoField"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:hint="Adicionar Saldo"
        app:layout_constraintBottom_toTopOf="@+id/IdDescricao"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.909"
        android:textColorHint="@color/gray_400"/>

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/IdDescricao"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:layout_marginTop="104dp"
        android:hint="Descrição"
        android:textColorHint="@color/gray_400"
        app:layout_constraintBottom_toTopOf="@+id/spinnerContaBanco"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.924" />

    <Button
        android:id="@+id/AddSaldoButton"
        style="@style/Widget.AppCompat.Button"
        android:layout_width="126dp"
        android:layout_height="65dp"
        android:background="@drawable/borda_personalizada"
        android:text="Adicionar"
        app:backgroundTint="@color/menuColor"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spinnerStatus"
        app:layout_constraintVertical_bias="0.662" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCalendarBalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:clickable="true"
        app:layout_constraintBottom_toTopOf="@+id/AddSaldoButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.107"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="?attr/popupMenuBackground" />

    <CalendarView
        android:id="@+id/calendarBalance"
        android:layout_width="305dp"
        android:layout_height="315dp"
        android:background="@color/white"
        android:theme="@style/Theme.AppCompat.Light"
        app:layout_constraintBottom_toTopOf="@+id/AddSaldoButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toEndOf="@+id/fabCalendarBalance" />

    <TextView
        android:id="@+id/dataCalendar"
        android:layout_width="233dp"
        android:layout_height="46dp"
        android:layout_marginBottom="80dp"
        android:text="Data"
        app:layout_constraintBottom_toTopOf="@+id/AddSaldoButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.617"
        app:layout_constraintStart_toEndOf="@+id/fabCalendarBalance" />

    <Spinner
        android:id="@+id/spinnerBalance"
        android:layout_width="281dp"
        android:layout_height="58dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spinnerContaBanco" />

    <Spinner
        android:id="@+id/spinnerStatus"
        android:layout_width="281dp"
        android:layout_height="58dp"
        android:layout_marginTop="344dp"
        android:layout_marginBottom="27dp"
        app:layout_constraintBottom_toTopOf="@+id/StatusId"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar2" />

    <Spinner
        android:id="@+id/spinnerContaBanco"
        android:layout_width="281dp"
        android:layout_height="58dp"
        android:layout_marginTop="212dp"
        android:layout_marginBottom="27dp"
        app:layout_constraintBottom_toTopOf="@+id/StatusId"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar2" />

</androidx.constraintlayout.widget.ConstraintLayout>